{
  "class": "ADC",
  "schemaVersion": "3.54.0",
  "id": "app-web",
  "Tenant_Web": {
    "class": "Tenant",
    "App_Web": {
      "class": "Application",
      "template": "generic",
      "service": {
        "class": "Service_HTTP",
        "virtualAddresses": [
          "192.0.2.10"
        ],
        "virtualPort": 80,
        "pool": "web_pool",
        "iRules": [
          "route_by_uri"
        ]
      },
      "web_pool": {
        "class": "Pool"
      },
      "api_pool": {
        "class": "Pool"
      },
      "route_by_uri": {
        "class": "iRule",
        "iRule": "when HTTP_REQUEST { }"
      },
      "allowed_hosts": {
        "class": "Data_Group_String"
      }
    }
  }
}
